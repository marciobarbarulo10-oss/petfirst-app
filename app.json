{
  "expo": {
    "name": "PetFirst",
    "slug": "petfirst",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFDF9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.petfirst.app",
      "infoPlist": {
        "NSCameraUsageDescription": "O PetFirst precisa de acesso à câmera para você tirar fotos do seu pet.",
        "NSPhotoLibraryUsageDescription": "O PetFirst precisa de acesso às suas fotos para você escolher uma foto do seu pet."
      }
    },
    "android": {
      "package": "com.petfirst.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFDF9"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "O PetFirst precisa de acesso às suas fotos para você escolher uma foto do seu pet.",
          "cameraPermission": "O PetFirst precisa de acesso à câmera para você tirar fotos do seu pet."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1af577b7-4234-4b77-8073-47e2da9574ee"
      }
    },
    "owner": "misaebarbarulo"
  }
}
